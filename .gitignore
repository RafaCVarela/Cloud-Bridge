# Cloud-Bridge — .gitignore

# ──────────────────────────────────────────────────────────────────────────────
# SEGREDOS — NUNCA faça commit destes arquivos!
# ──────────────────────────────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
.env
!.env.example
terraform.tfvars
!terraform.tfvars.example
secrets/
credentials/
*.secret

# ──────────────────────────────────────────────────────────────────────────────
# Terraform
# ──────────────────────────────────────────────────────────────────────────────
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
terraform.tfstate.d/
*.tfplan
crash.log

# ──────────────────────────────────────────────────────────────────────────────
# Ansible
# ──────────────────────────────────────────────────────────────────────────────
ansible/roles/*/files/vault_pass
*.retry
.vault_pass

# ──────────────────────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/

# ──────────────────────────────────────────────────────────────────────────────
# Sistema operacional
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ──────────────────────────────────────────────────────────────────────────────
# IDEs
# ──────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml

# ──────────────────────────────────────────────────────────────────────────────
# Logs e temporários
# ──────────────────────────────────────────────────────────────────────────────
*.log
/tmp/
/temp/
governance/checklists/evidencias/

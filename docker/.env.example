################################################################################
# Cloud-Bridge — Variáveis de Ambiente Docker
# ATENÇÃO: Copie para .env e preencha com seus dados.
#          NUNCA faça commit do arquivo .env — ele contém segredos.
################################################################################

# Domínio da aplicação (ex: meusite.org.br)
DOMAIN=meusite.org.br

# E-mail para certificado SSL Let's Encrypt
ACME_EMAIL=responsavel@meusite.org.br

# Banco de Dados
DB_NAME=cloudbridge
DB_USER=cbadmin
DB_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI

# Cache Redis
REDIS_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI
